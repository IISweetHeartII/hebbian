{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["es2022"]
  },
  "include": ["lib/**/*.js", "bin/**/*.js"],
  "exclude": ["node_modules"]
}
